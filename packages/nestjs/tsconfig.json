{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "experimentalDecorators": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "paths": {
            "relayos/core": [
                "../core/dist/index.d.ts"
            ],
            "relayos/core/*": [
                "../core/dist/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts"
    ]
}
