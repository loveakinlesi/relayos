{
    "name": "relayos",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "build:watch": "tsup --watch",
        "test": "vitest run",
        "test:integration": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "relayos/core": "workspace:*"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "4.1.1",
        "@types/node": "^25.5.0",
        "tsup": "^8.5.1",
        "typescript": "^6.0.2",
        "vitest": "^4.1.1"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
