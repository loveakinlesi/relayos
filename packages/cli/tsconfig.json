{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": ".",
        "types": [
            "node"
        ],
        "paths": {
            "relayos/core": [
                "../core/src/index.ts"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/__tests__/**/*.spec.ts",
        "src/__tests__/**/*.integration.spec.ts"
    ]
}
